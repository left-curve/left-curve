{
  "name": "@left-curve/sdk",
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#actions/*": "./src/actions/*",
    "#account/*": "./src/account/*",
    "#chains/*": "./src/chains/*",
    "#clients/*": "./src/clients/*",
    "#errors/*": "./src/errors/*",
    "#http/*": "./src/http/*",
    "#hyperlane/*": "./src/hyperlane/*",
    "#signers/*": "./src/signers/*",
    "#transports/*": "./src/transports/*"
  },
  "scripts": {
    "bump": "npm version --no-git-tag-version",
    "ci": "pnpm lint",
    "clean": "rm -rf ./build && rm -rf node_modules && rm -rf tsconfig.tsbuildinfo",
    "clean:build": "rm -rf ./build",
    "lint": "pnpm biome check --write src",
    "lint:fix": "pnpm biome ci ./src",
    "test": "pnpm vitest run",
    "test:watch": "pnpm vitest",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' pnpm tsup --clean"
  },
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "typings": "./build/index.d.ts",
  "sideEffects": false,
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.cjs"
    },
    "./actions": {
      "source": "./src/actions/index.ts",
      "types": "./build/actions/index.d.ts",
      "import": "./build/actions/index.js",
      "default": "./build/actions/index.cjs"
    },
    "./hyperlane": {
      "source": "./src/hyperlane/index.ts",
      "types": "./build/hyperlane/index.d.ts",
      "import": "./build/hyperlane/index.js",
      "default": "./build/hyperlane/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "actions": [
        "./build/actions/index.d.ts"
      ],
      "hyperlane": [
        "./build/hyperlane/index.d.ts"
      ]
    }
  },
  "devDependencies": {
    "@left-curve/config": "workspace:^",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@left-curve/types": "workspace:^",
    "@left-curve/encoding": "workspace:^",
    "@left-curve/utils": "workspace:^",
    "@left-curve/crypto": "workspace:^",
    "eventemitter3": "catalog:",
    "graphql": "^16.10.0"
  },
  "peerDependencies": {
    "graphql-ws": ">=6.0.0"
  },
  "license": "TBD",
  "homepage": "https://dango.exchange",
  "repository": "left-curve/left-curve",
  "keywords": [
    "grug",
    "dango",
    "smart-contracts",
    "blockchain",
    "cryptocurrency",
    "web3",
    "typescript"
  ]
}
