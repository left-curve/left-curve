{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "ci": {},
    "lint": {},
    "lint:fix": {},
    "clean": {
      "cache": false
    },
    "clean:build": {
      "cache": false
    },
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "build/**"]
    },
    "@left-curve/docs#build": {
      "outputs": ["dist/**"]
    }
  },
  "globalEnv": [
    "CONFIG_ENVIRONMENT",
    "PUBLIC_FP",
    "PUBLIC_WS_URI",
    "PUBLIC_SENTRY_DSN",
    "PUBLIC_SENTRY_ENVIRONMENT",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_AUTH_TOKEN",
    "GITHUB_TOKEN",
    "PUBLIC_PRIVY_APP_ID",
    "PUBLIC_PRIVY_CLIENT_ID",
    "ENABLED_FEATURES",
    "GIT_COMMIT",
    "R2_ASSETS_PREFIX"
  ]
}
