{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "ci": {},
    "lint": {},
    "lint:fix": {},
    "clean": {
      "cache": false
    },
    "clean:build": {
      "cache": false
    },
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "build/**"]
    },
    "@left-curve/docs#build": {
      "outputs": ["dist/**"]
    },
    "@left-curve/foundation#build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "paraglide/**"]
    },
    "@left-curve/portal-web#build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"],
      "env": [
        "CONFIG_ENVIRONMENT",
        "PUBLIC_FP",
        "PUBLIC_WS_URI",
        "PUBLIC_SENTRY_DSN",
        "PUBLIC_SENTRY_ENVIRONMENT",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "PUBLIC_PRIVY_APP_ID",
        "PUBLIC_PRIVY_CLIENT_ID",
        "ENABLED_FEATURES"
      ]
    }
  },
  "globalPassThroughEnv": [
    "GIT_COMMIT",
    "R2_ASSETS_PREFIX",
    "GITHUB_TOKEN",
    "SENTRY_AUTH_TOKEN"
  ]
}
