# ----------------------------- Referral Dashboard -----------------------------

# Deploy referral-dashboard for a network on a specific server.
# `server` is the tailscale IP (or any inventory host pattern within the
# referral-dashboard group) — pin to a single host so you can test on devnet
# before mainnet.
# Usage: just deploy-referral-dashboard devnet 100.107.248.71
#        just deploy-referral-dashboard testnet 100.109.200.70 v1.2.3
#        just deploy-referral-dashboard mainnet 100.76.197.30
deploy-referral-dashboard network server tag="latest":
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook referral-dashboard.yml \
      -e '{"referral_dashboard_networks": ["{{network}}"], "referral_dashboard_tag": "{{tag}}"}' \
      --limit {{server}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-deploy-referral-dashboard.log

stop-referral-dashboard network server:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook stop-referral-dashboard.yml \
      -e '{"referral_dashboard_networks": ["{{network}}"]}' \
      --limit {{server}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-stop-referral-dashboard.log

# Drop and recreate the referral-dashboard postgres database (full reindex on next deploy).
drop-db-referral-dashboard network server:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook drop-db-referral-dashboard.yml \
      -e '{"referral_dashboard_networks": ["{{network}}"]}' \
      --limit {{server}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-drop-db-referral-dashboard.log


# ---------------------------- Archive -----------------------------

deploy-archive-mainnet tag="latest":
  just deploy-archive mainnet {{tag}}

deploy-archive-testnet tag="latest":
  just deploy-archive testnet {{tag}}

# Deploy a network's archive instance(s), as configured in the host_vars
# (`archive_instances`) of the hosts in the [archive-<network>] inventory
# group.
# Usage: just deploy-archive mainnet
#        just deploy-archive testnet v1.2.3
deploy-archive network tag="latest":
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook archive.yml \
      -e archive_tag={{tag}} \
      --limit archive-{{network}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-deploy-archive.log

# Bootstrap public exposure for an archive network. Run this the first time a
# host is exposed publicly, or after changing Traefik/Cloudflare routing. Normal
# image deploys should use `deploy-archive`.
setup-archive-public network tag="latest":
  mkdir -p {{justfile_directory()}}/logs \
    && { \
      uv run ansible-playbook traefik.yml --limit archive-{{network}} \
      && uv run ansible-playbook archive.yml -e archive_tag={{tag}} --limit archive-{{network}} \
      && uv run ansible-playbook cloudflared.yml --limit archive-{{network}}; \
    } 2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-setup-archive-public.log

# Reconcile the shared Traefik stack/static config for archive hosts.
update-archive-traefik network:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook traefik.yml \
      --limit archive-{{network}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-update-archive-traefik.log

# Reconcile Cloudflared, archive DNS records, and archive Cloudflare LB state.
update-archive-cloudflare network:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook cloudflared.yml \
      --limit archive-{{network}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-update-archive-cloudflare.log

stop-archive network:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook stop-archive.yml \
      --limit archive-{{network}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-stop-archive.log

# Drop and recreate the projection database(s) — full reindex on next deploy;
# the RocksDB block store is preserved.
drop-db-archive network:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook drop-db-archive.yml \
      --limit archive-{{network}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-drop-db-archive.log


