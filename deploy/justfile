deploy-mainnet dango_image_tag bots_image_tag:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook full-app.yml \
      -e '{"traefik_enabled": true, "cometbft_generate_keys": true, "github_deployments_enabled": false, "expose_ports": false, "delete_postgres_database_at_merge": false, "delete_clickhouse_database_at_merge": false, "deploy_includes_postgres": false, "deploy_includes_clickhouse": false, "chain_id": "dango-1", "dango_network": "mainnet", "system_wide_directories": true, "deploy_env": "production"}' \
      -e dango_image_tag={{dango_image_tag}} \
      -e faucet_bot_tag={{bots_image_tag}} \
      -e perps_bot_tag={{bots_image_tag}} \
      -e perp_liquidator_tag={{bots_image_tag}} \
      -e withdrawal_approver_tag={{bots_image_tag}} \
      --limit {{hetzner5}},{{hetzner6}},{{hetzner1}},{{hetzner3}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-deploy-mainnet.log"

stop-mainnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook stop-services.yml \
      -e dango_network=mainnet \
      --limit {{hetzner5}},{{hetzner6}},{{hetzner1}},{{hetzner3}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-stop-mainnet.log"

restart-mainnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook restart-services.yml \
      -e dango_network=mainnet \
      --limit {{hetzner5}},{{hetzner6}},{{hetzner1}},{{hetzner3}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-restart-mainnet.log"

remove-deploy-lock-mainnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook remove-deploy-locks.yml \
      -e dango_network=mainnet \
      --limit {{hetzner5}},{{hetzner6}},{{hetzner1}},{{hetzner3}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-remove-deploy-lock-mainnet.log"

# Pull mainnet docker images on every host without restarting anything.
# Layers already present locally are not re-downloaded, so this is cheap to
# re-run and safe to use as a warm-up before `deploy-mainnet`.
pull-docker-images-mainnet dango_image_tag bots_image_tag:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook pull-docker-images.yml \
      -e dango_network=mainnet \
      -e dango_image_tag={{dango_image_tag}} \
      -e faucet_bot_tag={{bots_image_tag}} \
      -e perps_bot_tag={{bots_image_tag}} \
      -e perp_liquidator_tag={{bots_image_tag}} \
      -e withdrawal_approver_tag={{bots_image_tag}} \
      --limit {{hetzner5}},{{hetzner6}},{{hetzner1}},{{hetzner3}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-pull-docker-images-mainnet.log"

# ---------------------------------- Preview -----------------------------------

deploy-preview-latest:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook full-app.yml \
      -e '{"expose_ports": true, "perps_bot_enabled": true, "faucet_bot_enabled": true, "cometbft_generate_keys":true}' \
      -e deploy_env=preview \
      -e dango_image_tag=latest \
      -e dango_network=previewnet \
      -e chain_id=preview \
      --limit {{ovh1}},{{ovh2}},{{ovh3}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-deploy-preview-latest.log"

# List all PR deployments with age on ovh1 and ovh2
list-pr-deploys:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook list-pr-deploys.yml \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-list-pr-deploys.log

# Delete the deploy of a specific PR
delete-pr number:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook delete-full-app.yml \
      -e deployment_name=pr-{{number}} \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-delete-pr.log

# Delete a specific devnet deploy by timestamp (e.g. just delete-devnet-deploy 20260122064234)
delete-devnet-deploy timestamp:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook delete-old-devnet-deploys.yml \
      -e deployment_name={{timestamp}} \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-delete-devnet-deploy.log

# Delete a specific devnet deploy AND its data directory under ~/devnet/<timestamp>
delete-devnet-deploy-with-data timestamp:
  mkdir -p {{justfile_directory()}}/logs \
    && uv run ansible-playbook delete-old-devnet-deploys.yml \
      -e deployment_name={{timestamp}} \
      -e remove_devnet_data=true \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee {{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-delete-devnet-deploy-with-data.log

# --------------------------------- Hyperlane ----------------------------------

# Deploy Hyperlane agent locally
# Usage: just hyperlane-local testnet relayer
#        just hyperlane-local testnet validator 1
# Valid values:
#   network: testnet, mainnet
#   agent: relayer, validator
#   index: required for validator (e.g. "1", "2"), optional for relayer
deploy-hyperlane network agent limit index="":
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook -i inventory hyperlane.yml \
      -e hyperlane_agents_network={{network}} \
      -e hyperlane_agent_type={{agent}} \
      -e hyperlane_validator_index={{index}} \
      --limit {{limit}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-deploy-hyperlane.log"

deploy-hyperlane-mainnet:
  just deploy-hyperlane mainnet validator {{hetzner5}} 1
  just deploy-hyperlane mainnet validator {{hetzner6}} 2
  just deploy-hyperlane mainnet validator {{hetzner1}} 3
  just deploy-hyperlane mainnet validator {{hetzner3}} 4
  just deploy-hyperlane mainnet relayer {{hetzner3}}

deploy-hyperlane-relayer-mainnet:
  just deploy-hyperlane mainnet relayer {{hetzner3}}

deploy-hyperlane-testnet:
  just deploy-hyperlane testnet validator {{hetzner2}} 1
  just deploy-hyperlane testnet validator {{hetzner4}} 2
  just deploy-hyperlane testnet relayer {{hetzner4}}

# Stop a single Hyperlane instance
# Usage: just stop-hyperlane mainnet validator 100.72.62.100 1
#        just stop-hyperlane testnet relayer 100.109.200.70
stop-hyperlane network agent limit index="":
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook -i inventory stop-hyperlane.yml \
      -e hyperlane_agents_network={{network}} \
      -e hyperlane_agent_type={{agent}} \
      -e hyperlane_validator_index={{index}} \
      --limit {{limit}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-stop-hyperlane.log"

stop-hyperlane-mainnet-validators:
  just stop-hyperlane mainnet validator {{hetzner5}} 1
  just stop-hyperlane mainnet validator {{hetzner6}} 2
  just stop-hyperlane mainnet validator {{hetzner1}} 3
  just stop-hyperlane mainnet validator {{hetzner3}} 4

stop-hyperlane-testnet-validators:
  just stop-hyperlane testnet validator {{hetzner2}} 1
  just stop-hyperlane testnet validator {{hetzner4}} 2

# Start only the dango container (httpd + indexer) without CometBFT.
# Useful for querying blocks/state when the chain can't run.
# Usage: just start-dango-httpd mainnet <IP>
start-dango-httpd network limit:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook start-dango-httpd.yml \
      -e dango_network={{network}} \
      --limit {{limit}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-start-dango-httpd.log"

# Print validator address from AWS KMS (cast)
# Usage: just hyperlane-kms-address testnet 1
hyperlane-kms-address network index:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook hyperlane-kms-address.yml \
      -e hyperlane_agents_network={{network}} \
      -e hyperlane_validator_index={{index}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-hyperlane-kms-address.log"

