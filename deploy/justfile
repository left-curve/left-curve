# -------------------------------- Provisioning --------------------------------

cold-provision:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook playbook.yml \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-cold-provision.log"

provision:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook playbook.yml \
      --skip-tags setup \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-provision.log"

# Apply the users role (create accounts, sync SSH authorized_keys) on all servers
provision-users:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook users.yml \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-provision-users.log"

# ---------------------------------- Devnet ------------------------------------

deploy-devnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook full-app.yml \
      -e '{"traefik_enabled": true, "cometbft_generate_keys": true, "perps_bot_enabled": true, "github_deployments_enabled": false, "expose_ports": false, "delete_postgres_database_at_merge": false, "delete_clickhouse_database_at_merge": false, "deploy_includes_postgres": false, "deploy_includes_clickhouse": false, "dango_network": "devnet", "deploy_env": "production", "chain_id": "dev-9", "dango_image_tag": "latest", "system_wide_directories": true}' \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-deploy-devnet.log"

reset-and-deploy-devnet:
  just stop-devnet
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook full-app.yml \
      -e '{"traefik_enabled": true, "cometbft_generate_keys": true, "perps_bot_enabled": true, "github_deployments_enabled": false, "expose_ports": false, "delete_postgres_database_at_merge": false, "delete_clickhouse_database_at_merge": false, "deploy_includes_postgres": false, "deploy_includes_clickhouse": false, "dango_network": "devnet", "deploy_env": "production", "chain_id": "dev-9", "dango_image_tag": "latest", "system_wide_directories": true, "reset_data": true}' \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-reset-and-deploy-devnet.log"

stop-devnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook stop-services.yml \
      -e dango_network=devnet \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-stop-devnet.log"

# Delete the devnet deployment entirely (docker compose down, remove dir, prune).
# Fetches the current deployment name from ~/deployments/devnet.json on ovh1.
# Usage: just delete-devnet
delete-devnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && TIMESTAMP=$(ssh deploy@{{ovh1}} 'jq -r .current_deployment /home/deploy/deployments/devnet.json') \
    && test -n "$TIMESTAMP" \
    && test "$TIMESTAMP" != "null" \
    && echo "Deleting devnet deployment: $TIMESTAMP" \
    && uv run ansible-playbook delete-full-app.yml \
      -e deployment_name="$TIMESTAMP" \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-delete-devnet.log"

restart-devnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook restart-services.yml \
      -e dango_network=devnet \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-restart-devnet.log"

remove-deploy-lock-devnet:
  mkdir -p "{{justfile_directory()}}/logs" \
    && uv run ansible-playbook remove-deploy-locks.yml \
      -e dango_network=devnet \
      --limit {{ovh1}},{{ovh2}} \
      2>&1 | tee "{{justfile_directory()}}/logs/$(date -u +%Y%m%d%H%M%S)-remove-deploy-lock-devnet.log"

