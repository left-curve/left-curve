{
  "block_task": {
    "initial_loops": 2,
    "max_loops": 100,
    "timeout": "30s"
  },
  "bot": {
    "epoch_duration": "10m",
    "event_duration": 4320,
    "event_start": {
      "block": 2
    },
    "from_block": 2,
    "loot_tables": {{ (points_bot_loot_tables[network] | default({})) | to_nice_json(indent=2) | indent(4) }},
    "perps_expression": "1 + max(0.0, math::log10(x))",
    "epoch_perps_share": "750000",
    "epoch_vault_points": "250000",
    "leaderboard_timeframes": [1, 2, 4],
    "blacklist": {{ (points_bot_blacklist[network] | default([])) | to_nice_json(indent=2) | indent(4) }}
  },
  "http_url": "https://api-devnet.dango.zone",
  "httpd": {
    "register_cache_delta": "1m",
    "rest_url": "0.0.0.0:8080",
    "leaderboard_refresh_interval": "1m",
    "predict_points_refresh_interval": "2m"
  },
  "log_level": "info",
  "referral": {
    "direct_share": "0.2",
    "indirect_share": "0.05"
  },
  "boost": {
    "oat": {
      "multiplier": "1",
      "window": "2weeks"
    },
    "user": {{ (points_bot_user_boosts[network] | default({})) | to_nice_json(indent=2) | indent(4) }},
    "referral": {{ (points_bot_referral_boosts[network] | default({})) | to_nice_json(indent=2) | indent(4) }},
    "pair": {}
  }
}
