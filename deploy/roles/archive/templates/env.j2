# Managed by Ansible (archive role) — do not edit on the host.
# Injected into the container via `env_file`; config-rs reads these as
# SECTION__FIELD overrides on top of app.toml. Only the deployment-specific
# values are injected here — everything else stays in app.toml so that file
# remains the single place to read an instance's configuration. The
# block_source *variant* cannot be switched from env (only its fields can be
# overridden); both overrides below — including live_url reaching inside the
# tagged `block_source` table — are covered by the cli config unit test.
POSTGRES__URL=postgres://{{ archive_db_user }}:{{ archive_db_password | urlencode }}@{{ archive_db_host }}:{{ archive_db_port }}/{{ archive_db_name }}
BLOCK_SOURCE__LIVE_URL={{ instance.live_url }}
