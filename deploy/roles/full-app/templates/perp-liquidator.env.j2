{% set cfg = perp_liquidator_config[dango_network] | default(perp_liquidator_config['previewnet']) %}
{% set inst = cfg.instances[perp_liquidator_instance_index | int] %}
{% set secrets = perp_liquidator_secrets[dango_network][perp_liquidator_instance_index | int] %}
name={{ inst.name }}
http_url={{ cfg.http_url }}

# -------- SIGNER CONFIGURATION --------
address={{ secrets.address }}
key__privatekey={{ secrets.private_key }}

# -------- LIQUIDATION SETTINGS --------
liquidation_cooldown={{ cfg.liquidation_cooldown }}
liquidation_delay_blocks={{ inst.liquidation_delay_blocks }}
event_driven={{ cfg.event_driven }}

# -------- QUERY TIMEOUTS --------
query_timeout={{ cfg.query_timeout }}
query_timeout_heavy={{ cfg.query_timeout_heavy }}

# -------- HTTP STATUS SERVER --------
http_port={{ cfg.http_port }}

# -------- FRONTEND --------
frontend_url={{ cfg.frontend_url }}

# -------- NOTIFICATIONS --------
{% if secrets.discord_webhook_url is defined %}
discord_webhook_url={{ secrets.discord_webhook_url }}
{% endif %}
{% if secrets.telegram_bot_token is defined %}
telegram_bot_token={{ secrets.telegram_bot_token }}
telegram_chat_id={{ secrets.telegram_chat_id }}
{% endif %}
{% if cfg.notification_timeout is defined %}
notification_timeout={{ cfg.notification_timeout }}
{% endif %}
