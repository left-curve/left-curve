# Managed by Ansible (historical-indexer role) — do not edit on the host.
# Injected into the container via `env_file`; config-rs reads these as
# SECTION__FIELD overrides on top of app.toml. Only string-valued fields are
# safe here — the parser does not coerce types from env, so numeric/bool fields
# and the block_source variant stay in app.toml. live_url is a string and the
# variant is fixed in app.toml, so overriding it here works (covered by a
# config unit test).
POSTGRES__URL=postgres://{{ hi_db_user }}:{{ historical_indexer_db_password | urlencode }}@{{ historical_indexer_db_host }}:{{ historical_indexer_db_port }}/{{ hi_db_name }}
BLOCK_SOURCE__LIVE_URL={{ instance.live_url }}
