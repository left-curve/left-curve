{
  "name": "leftcurve-monorepo",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "pnpm": ">=10.16.1",
    "node": ">=23.0.0"
  },
  "scripts": {
    "turbo": "turbo",
    "clean": "turbo clean && rm -rf node_modules",
    "clean:build": "turbo clean:build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:sdk": "turbo lint -F=./sdk/typescript/**",
    "test": "turbo test",
    "test:sdk": "turbo test -F=./sdk/typescript/**",
    "dev": "turbo dev",
    "test:e2e": "pnpm portal-web test:e2e",
    "machine-translate": "pnpm -F ui-config machine-translate",
    "dev:portal-web": "pnpm -F @left-curve/portal-web dev",
    "dev:portal-app": "turbo dev -F @left-curve/foundation -F @left-curve/portal-app",
    "dev:docs": "pnpm -F @left-curve/docs dev",
    "build:sdk": "turbo build -F=./sdk/typescript/**",
    "build:graph": "turbo build --graph=build-graph.png",
    "build:portal-web": "turbo build -F @left-curve/portal-web",
    "build:kit": "turbo build -F @left-curve/applets-kit",
    "build:portal-app": "pnpm portal-app build:ios",
    "build:docs": "turbo build -F @left-curve/docs",
    "storybook": "pnpm -F applets-kit sb:dev",
    "portal-web": "pnpm -F portal-web",
    "portal-app": "pnpm -F portal-app",
    "dango": "pnpm -F dango",
    "foundation": "pnpm -F foundation",
    "grug": "pnpm -F grug",
    "kit": "pnpm -F applets-kit",
    "bump": "pnpm -r 'bump'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "catalog:",
    "tsup": "^8.3.0",
    "turbo": "^2.0.11",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@storybook/icons": "^2.0.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "typescript",
        "tsup",
        "@biomejs/biome"
      ]
    }
  }
}
