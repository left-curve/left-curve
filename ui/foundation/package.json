{
  "name": "@left-curve/foundation",
  "version": "0.1.1",
  "private": true,
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "typings": "./build/index.d.ts",
  "type": "module",
  "exports": {
    "./fonts/*": "./fonts/*",
    "./images/*": "./images/*",
    "./tailwind/*": "./tailwind/*",
    "./messages/*": "./messages/*",
    "./inlang/*": "./project.inlang/*",
    "./paraglide/*": "./paraglide/*",
    "./coins": "./coins.ts",
    ".": {
      "source": "./react/index.ts",
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.cjs"
    }
  },
  "scripts": {
    "inlang": "inlang",
    "machine-translate": "inlang machine translate --project ./project.inlang",
    "ci": "pnpm lint",
    "lint": "pnpm biome check --write ./react ./tailwind ./coins.ts ./paraglide.ts ./tsup.config.ts",
    "lint:fix": "pnpm biome ci ./react ./tailwind ./coins.ts ./paraglide.ts ./tsup.config.ts",
    "clean": "rm -rf ./build && rm -rf node_modules && rm -rf tsconfig.tsbuildinfo",
    "clean:build": "rm -rf ./build",
    "dev": "nodemon",
    "build": "node paraglide.ts && pnpm tsup --clean"
  },
  "dependencies": {
    "@inlang/cli": "^3.0.3",
    "@inlang/paraglide-js": "^2.2.0",
    "@left-curve/store": "workspace:^",
    "date-fns-tz": "^3.2.0",
    "html-to-image": "^1.11.13",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "catalog:",
    "tailwindcss-animate": "^1.0.7",
    "clsx": "^2.1.1",
    "tailwind-variants": "catalog:",
    "@left-curve/types": "workspace:^",
    "@left-curve/encoding": "workspace:^",
    "@left-curve/utils": "workspace:^"
  },
  "devDependencies": {
    "react": "catalog:",
    "@types/react": "catalog:",
    "@left-curve/config": "workspace:^",
    "@types/date-fns": "catalog:",
    "date-fns": "catalog:",
    "nodemon": "^3.1.10"
  },
  "peerDependencies": {
    "date-fns": ">=4.0.0",
    "react": "^18 || ^19"
  },
  "nodemonConfig": {
    "watch": [
      "messages"
    ],
    "exec": "node paraglide.ts"
  }
}
