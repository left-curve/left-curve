{
  "extends": ["expo/tsconfig.base"],
  "compilerOptions": {
    "strict": true,
    "paths": {
      "~/assets/*": ["./assets/*"],
      "~/store": ["./store.config.ts"],
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "../../foundation/shared/tailwind/config.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    {
      "path": "../../foundation/app"
    },
    {
      "path": "../../../sdk/dango"
    },
    {
      "path": "../../store"
    }
  ]
}
